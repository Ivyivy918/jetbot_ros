<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/casterDriver.STL"/>
</geometry>
</collision>
</link>
<joint name="casterDriver" type="fixed">
<origin xyz="0.060069 -0.0069739 -0.019048" rpy="0 0 0"/>
<parent link="base_link"/>
<child link="casterDriver"/>
</joint>
<!-- ── CASTER SPHERE ── -->
<link name="caster">
<inertial>
<origin xyz="8.879E-05 0.0068776 -0.00994" rpy="0 0 0"/>
<mass value="0.0080425"/>
<inertia ixx="4.1196E-07" ixy="1.0349E-10" ixz="-2.1506E-09" iyy="7.8279E-07" iyz="1.0848E-09" izz="6.5857E-07"/>
</inertial>
<visual>
