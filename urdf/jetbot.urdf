</geometry>
</collision>
</link>
<joint name="caster" type="fixed">
<origin xyz="-0.025083 0.0099121 -0.01492" rpy="-1.5708 0 0"/>
<parent link="casterDriver"/>
<child link="caster"/>
</joint>
</robot>