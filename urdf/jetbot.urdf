
<!--
 JetBot URDF — fixed from sw2urdf export
     Changes vs original:
       1. Added base_footprint link (ground reference for RViz)
       2. wheelLeft/wheelRight: removed <limit lower=0 upper=0> (caused TF break)
       3. wheelLeft/wheelRight: axis corrected to "0 0 1" (joint-local Z after rpy rotation)
       4. camera_right: mass/inertia corrected to match camera_left
       5. Package name kept as "assembly_urdf" — just replace with your actual package name
-->
<robot name="jetbot_urdf">
<!--
-->
<link name="base_footprint"/>
<joint name="base_footprint_joint" type="fixed">
  <parent link="base_footprint"/>
  <child link="base_link"/>
  <origin xyz="0 0 0.034" rpy="0 0 0"/>
</joint>

<!-- ── BASE LINK ── -->
<link name="base_link">
<inertial>
<origin xyz="4.5687E-07 1.7455E-05 -0.0019999" rpy="0 0 0"/>
<mass value="0.0768"/>
<inertia ixx="9.2268E-05" ixy="-6.2493E-07" ixz="-4.2858E-08" iyy="0.00016394" iyz="-8.036E-07" izz="0.00025599"/>
</inertial>
<visual>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/base_link.STL"/>
</geometry>
<material name="chassis">
<color rgba="0.79216 0.81961 0.93333 1"/>
</material>
</visual>
<collision>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/base_link.STL"/>
</geometry>
</collision>
</link>
<!-- ── LEFT WHEEL ── -->
<link name="wheel_left">
<inertial>
<origin xyz="0.000116 0.000116 -0.013299" rpy="0 0 0"/>
<mass value="0.0966027174608247"/>
<inertia ixx="3.36159E-05" ixy="1.69143E-09" ixz="-1.93841E-07" iyy="3.36159E-05" iyz="-1.93878E-07" izz="5.58330E-05"/>
</inertial>
<visual>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/wheel_left.STL"/>
</geometry>
<material name="wheel">
<color rgba="0.15 0.15 0.15 1"/>
</material>
</visual>
<collision>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/wheel_left.STL"/>
</geometry>
</collision>
</link>
<joint name="wheelLeft" type="continuous">
<origin xyz="-0.034751 0.086437 -0.015254" rpy="-1.5708 0 0"/>
<parent link="base_link"/>
<child link="wheel_left"/>
<!--
 FIX: axis corrected to joint-local Z (= world Y after rpy="-1.5708 0 0") 
-->
<axis xyz="0 0 1"/>
<!--
 FIX: removed <limit lower=0 upper=0> — caused TF break 
-->
<dynamics damping="0.1" friction="0.1"/>
</joint>
<!-- ── RIGHT WHEEL ── -->
<link name="wheel_right">
<inertial>
<origin xyz="-0.000116 0.000116 -0.013299" rpy="0 0 0"/>
<mass value="0.0966027174608247"/>
<inertia ixx="3.36159E-05" ixy="-1.69143E-09" ixz="1.93841E-07" iyy="3.36159E-05" iyz="-1.93878E-07" izz="5.58330E-05"/>
</inertial>
<visual>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/wheel_right.STL"/>
</geometry>
<material name="wheel">
<color rgba="0.15 0.15 0.15 1"/>
</material>
</visual>
<collision>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/wheel_right.STL"/>
</geometry>
</collision>
</link>
<joint name="wheelRight" type="continuous">
<origin xyz="-0.03324 -0.08675 -0.016765" rpy="1.5708 0 0"/>
<parent link="base_link"/>
<child link="wheel_right"/>
<!--
 FIX: axis corrected (rpy="1.5708 0 0" also rotates Z → Y, but flipped) 
-->
<axis xyz="0 0 1"/>
<!-- FIX: removed <limit lower=0 upper=0> -->
<dynamics damping="0.1" friction="0.1"/>
</joint>
<!-- ── ARM1 (vertical) ── -->
<link name="arm1">
<inertial>
<origin xyz="-0.001500 -1.308E-05 -4.568E-07" rpy="0 0 0"/>
<mass value="0.0132"/>
<inertia ixx="1.5070E-05" ixy="1.5239E-08" ixz="3.1713E-09" iyy="1.3319E-05" iyz="1.0080E-07" izz="1.7708E-06"/>
</inertial>
<visual>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/arm1.STL"/>
</geometry>
<material name="chassis">
<color rgba="0.79216 0.81961 0.93333 1"/>
</material>
</visual>
<collision>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/arm1.STL"/>
</geometry>
</collision>
</link>
<joint name="arm1" type="fixed">
<origin xyz="0.074985 0.00017408 0.055021" rpy="0 0 0"/>
<parent link="base_link"/>
<child link="arm1"/>
</joint>
<!-- ── ARM2 (horizontal bar) ── -->
<link name="arm2">
<inertial>
<origin xyz="-0.001000 -8.721E-06 -3.046E-07" rpy="0 0 0"/>
<mass value="0.0064"/>
<inertia ixx="1.3866E-05" ixy="1.1908E-07" ixz="1.0873E-09" iyy="2.1753E-07" iyz="-1.1726E-07" izz="1.3654E-05"/>
</inertial>
<visual>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/arm2.STL"/>
</geometry>
<material name="chassis">
<color rgba="0.79216 0.81961 0.93333 1"/>
</material>
</visual>
<collision>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/arm2.STL"/>
</geometry>
</collision>
</link>
<joint name="arm2" type="fixed">
<origin xyz="0.0019912 -0.0003142 0.037999" rpy="0 0 0"/>
<parent link="arm1"/>
<child link="arm2"/>
</joint>
<!-- ── CAMERA LEFT ── -->
<link name="camera_left">
<inertial>
<origin xyz="-0.001500 -1.308E-05 -4.568E-07" rpy="0 0 0"/>
<mass value="0.00011545"/>
<inertia ixx="7.0713E-10" ixy="2.3284E-12" ixz="8.1308E-14" iyy="4.4019E-10" iyz="7.0913E-16" izz="4.4017E-10"/>
</inertial>
<visual>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/camera_left.STL"/>
</geometry>
<material name="camera">
<color rgba="0.10 0.10 0.10 1"/>
</material>
</visual>
<collision>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/camera_left.STL"/>
</geometry>
</collision>
</link>
<joint name="cameraLeft" type="fixed">
<origin xyz="0.0023543 0.074021 0.00064658" rpy="0 0 0"/>
<parent link="arm2"/>
<child link="camera_left"/>
</joint>
<!--
 Camera left optical frame (ROS REP-103: Z forward, X right) 
-->
<link name="camera_left_optical_frame"/>
<joint name="camera_left_optical_joint" type="fixed">
<parent link="camera_left"/>
<child link="camera_left_optical_frame"/>
<origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
</joint>
<!-- ── CAMERA RIGHT ── -->
<link name="camera_right">
<inertial>
<!--
 FIX: was 0.35788kg (whole robot!) — corrected to match camera_left 
-->
<origin xyz="-0.001500 -1.308E-05 -4.568E-07" rpy="0 0 0"/>
<mass value="0.00011545"/>
<inertia ixx="7.0713E-10" ixy="2.3284E-12" ixz="8.1308E-14" iyy="4.4019E-10" iyz="7.0913E-16" izz="4.4017E-10"/>
</inertial>
<visual>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/camera_right.STL"/>
</geometry>
<material name="camera">
<color rgba="0.10 0.10 0.10 1"/>
</material>
</visual>
<collision>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="package://jetbot_ros/meshes/camera_right.STL"/>
</geometry>
</collision>
</link>
<joint name="cameraRight" type="fixed">
<origin xyz="0.0036454 -0.073968 -0.00064475" rpy="0 0 0"/>
<parent link="arm2"/>
<child link="camera_right"/>
</joint>
<!-- Camera right optical frame -->
<link name="camera_right_optical_frame"/>
<joint name="camera_right_optical_joint" type="fixed">
<parent link="camera_right"/>
<child link="camera_right_optical_frame"/>
<origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
</joint>
<!-- ── CASTER DRIVER ── -->
<link name="casterDriver">
<inertial>
<origin xyz="-0.024999 -0.000218 -7.614E-06" rpy="0 0 0"/>
<mass value="0.06"/>
<inertia ixx="1.2500E-05" ixy="-3.9237E-08" ixz="-2.1699E-09" iyy="1.7000E-05" iyz="-3.0557E-08" izz="2.0500E-05"/>
